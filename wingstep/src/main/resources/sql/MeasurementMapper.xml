<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.wingstep.service.workrecord.MeasurementDao">

    <!-- ResultMap : measurement -> Measurement -->
    <resultMap id="MeasurementResultMap" type="Measurement">
        <id     property="measurementId"       column="measure_id"/>
        <result property="workRecordId"        column="workrecord_id"/>
        <result property="measurementDatetime" column="measure_datetime"/>
        <result property="measurementLocation" column="measure_location"/>
        <result property="speed"               column="speed"/>
        <result property="distance"            column="distance"/>
        <result property="steps"               column="steps"/>
        <result property="heartrate"           column="heartrate"/>
        <result property="calorie"             column="calorie"/>
    </resultMap>

    <!-- 측정기록 등록 -->
    <insert id="addMeasurement"
            parameterType="Measurement"
            useGeneratedKeys="true"
            keyProperty="measurementId">
        INSERT INTO MEASUREMENT (
            workrecord_id,
            measure_datetime,
            measure_location,
            speed,
            distance,
            steps,
            heartrate,
            calorie
        ) VALUES (
            #{workRecordId},
            #{measurementDatetime},
            ST_GeomFromText(
                CONCAT('POINT(',
                       REPLACE(#{measurementLocation}, ',', ' '),
                       ')'),
                4326
            ),
            #{speed},
            #{distance},
            #{steps},
            #{heartrate},
            #{calorie}
        )
    </insert>

    <!-- 마지막 측정기록 상세 조회 -->
    <select id="getLastMeasurement"
            parameterType="int"
            resultMap="MeasurementResultMap">
        SELECT
            measure_id,
            workrecord_id,
            measure_datetime,
            ST_AsText(measure_location) AS measure_location,
            speed,
            distance,
            steps,
            heartrate,
            calorie
        FROM MEASUREMENT
        WHERE workrecord_id = #{workRecordId}
        ORDER BY measure_datetime DESC
        LIMIT 1
    </select>

    <!-- 특정 WORKRECORD 의 전체 측정기록 조회 -->
    <select id="listMeasurement"
            parameterType="int"
            resultMap="MeasurementResultMap">
        SELECT
            measure_id,
            workrecord_id,
            measure_datetime,
            ST_AsText(measure_location) AS measure_location,
            speed,
            distance,
            steps,
            heartrate,
            calorie
        FROM MEASUREMENT
        WHERE workrecord_id = #{workRecordId}
        ORDER BY measure_datetime ASC
    </select>

    <!-- 특정 WORKRECORD 의 모든 측정기록 삭제 -->
    <delete id="deleteAllMeasurement"
            parameterType="int">
        DELETE FROM MEASUREMENT
        WHERE workrecord_id = #{workRecordId}
    </delete>

</mapper>
